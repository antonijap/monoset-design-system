{
  "name": "monoset-design-system",
  "private": true,
  "version": "0.0.0",
  "description": "Monoset:a minimal, monotone, unopinionated design system.",
  "workspaces": [
    "packages/*",
    "website",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=website",
    "test": "npm run test --workspaces --if-present",
    "test:versions": "node --test scripts/release-version-consistency.test.mjs",
    "test:workflows": "node --test scripts/workflow-boundaries.test.mjs",
    "test:react:v1": "pnpm --filter @monoset/react test && pnpm --filter @monoset/react test:contracts:types && pnpm --filter @monoset/react test:e2e && pnpm --filter @monoset/react verify:package",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "puppeteer-core": "^25.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.2"
}
