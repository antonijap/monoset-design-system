# Copy to .env.local and fill in the values you want.
# Anything prefixed VITE_ is embedded in the client bundle at build time.

# PostHog analytics (optional). Without a key, analytics stays a silent no-op.
# Create a project API key at https://eu.posthog.com → project settings.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
