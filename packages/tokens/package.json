{
  "name": "@monoset/tokens",
  "version": "1.0.0",
  "description": "Monoset design tokens , colors, type, spacing, radii, shadows, motion.",
  "keywords": [
    "design-system",
    "tokens",
    "monoset",
    "monotone"
  ],
  "license": "MIT",
  "files": [
    "src/tokens.js",
    "src/tokens.d.ts",
    "src/tokens.json",
    "src/index.css",
    "src/variables.css",
    "src/base.css",
    "src/typography.css",
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./src/tokens.js",
      "require": "./src/tokens.js",
      "types": "./src/tokens.d.ts"
    },
    "./css": "./src/index.css",
    "./variables.css": "./src/variables.css",
    "./base.css": "./src/base.css",
    "./typography.css": "./src/typography.css",
    "./json": "./src/tokens.json"
  },
  "main": "./src/tokens.js",
  "types": "./src/tokens.d.ts",
  "scripts": {
    "build": "echo 'No build step , CSS + JSON shipped as source'",
    "test": "vitest run"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
