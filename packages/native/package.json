{
  "name": "@monoset/native",
  "version": "0.4.1",
  "description": "Monoset for React Native. Monotone, minimal, unopinionated. Variant API on the surface, vanilla StyleSheet inside.",
  "keywords": [
    "design-system",
    "react-native",
    "components",
    "monoset",
    "monotone"
  ],
  "license": "MIT",
  "homepage": "https://monoset.design",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antonijap/monoset-design-system.git",
    "directory": "packages/native"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "import": "./dist/styles.js",
      "require": "./dist/styles.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "lucide-react-native": ">=0.400",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-svg": ">=13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lucide-react-native": "^0.462.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-svg": "^15.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0"
  }
}
