{
  "name": "@monoset/native",
  "version": "0.2.0",
  "description": "Monoset for React Native. Monotone, minimal, unopinionated. Variant API on the surface, vanilla StyleSheet inside.",
  "keywords": [
    "design-system",
    "react-native",
    "components",
    "monoset",
    "monotone"
  ],
  "license": "MIT",
  "homepage": "https://monoset.design",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antonijap/monoset-design-system.git",
    "directory": "packages/native"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "import": "./dist/styles.js",
      "require": "./dist/styles.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
