{
  "name": "@monoset/motion",
  "version": "1.0.0",
  "description": "Motion presets and shared timing values for Framer Motion.",
  "keywords": [
    "design-system",
    "motion",
    "framer-motion",
    "monoset"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "framer-motion": ">=11"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "framer-motion": "^12.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
